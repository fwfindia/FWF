# FWF Backend Environment Variables
# Copy to .env and edit values

# --- JWT Authentication ---
# Secret key for JWT token signing (min 32 characters)
# Generate: openssl rand -base64 32
JWT_SECRET=please_change_me_to_long_random_string_min_32_chars

# --- Server Configuration ---
PORT=3000
NODE_ENV=production

# --- Organization Settings ---
# Prefix for member IDs (e.g., FWF-000001)
ORG_PREFIX=FWF

# --- Admin Account (Auto-seeded on first run) ---
ADMIN_USER=admin@fwf
ADMIN_PASS=Admin@12345

# --- CORS (Comma-separated allowed origins) ---
ALLOWED_ORIGINS=http://localhost:3000,https://yoursite.com

# --- Twilio SMS OTP (preferred — no DLT registration required) ---
# Get from: https://console.twilio.com > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Get from: https://console.twilio.com > Phone Numbers > Manage > Active numbers
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# --- Error Monitoring (Optional) ---
# Get from https://sentry.io after creating a Node.js project
SENTRY_DSN=https://your_key@o123.ingest.sentry.io/456
